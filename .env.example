# Variabel lingkungan untuk development lokal
# Salin file ini menjadi .env dan sesuaikan nilainya

# Port server
PORT=3000

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=submissionmlgc-hilmibisri

# Nama bucket Cloud Storage yang menyimpan model
MODEL_BUCKET=submissionmlgc-hilmibisri-model

# Path model di dalam bucket
MODEL_PATH=models/model.json
